<?xml version="1.0" encoding="UTF-8"?>
<!-- Embedded into the binary via `-sectcreate __TEXT __info_plist` (see Makefile). A bare
     CLI has no Info.plist, so TCC has no usage string to show and the prompt can be empty
     or suppressed — empty transcripts. CFBundleIdentifier matches the codesign identifier
     (com.user.dictate) so the TCC identity is consistent. See CLAUDE.md gotcha #2. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.user.dictate</string>
    <key>CFBundleName</key>
    <string>dictate</string>
    <key>CFBundleExecutable</key>
    <string>dictate</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Диктовка использует микрофон для распознавания речи.</string>
</dict>
</plist>
